# SpeakUp Agent Demo 环境变量模板
# 使用方式：
#   1. 复制本文件为 .env.local
#   2. 填写真实密钥
#   3. 不要提交 .env.local（已被 .gitignore 忽略）

# -----------------------------------------------------------------------------
# 阿里云百炼 / DashScope
# -----------------------------------------------------------------------------

# 必填：中国内地（北京）地域的百炼 API Key。
export DASHSCOPE_API_KEY="sk-your-key"

# 可选：专属 Workspace ID。未配置时使用公共的中国内地 DashScope 域名。
export DASHSCOPE_WORKSPACE_ID=""

# 普通文字对话、记忆提取和内容处理所使用的模型。
export DASHSCOPE_CHAT_MODEL="qwen3.5-flash"
export DASHSCOPE_EMBEDDING_MODEL="text-embedding-v4"
export DASHSCOPE_DOCUMENT_MODEL="qwen-long"

# 普通录音模式下使用的语音识别和语音合成模型。
export DASHSCOPE_ASR_MODEL="qwen3-asr-flash-realtime"
export DASHSCOPE_TTS_MODEL="qwen-audio-3.0-tts-flash"
export DASHSCOPE_TTS_VOICE="longanhuan_v3.6"

# 端到端实时通话固定使用 qwen3.5-omni-flash-realtime。
# 可覆盖实时语音角色和 WebSocket 地址，但不能通过环境变量更换模型。
export DASHSCOPE_OMNI_VOICE="Tina"
export DASHSCOPE_OMNI_WEBSOCKET_URL=""

# 可选：覆盖 DashScope 服务地址。留空时根据 Workspace ID 自动生成。
export DASHSCOPE_COMPATIBLE_BASE_URL=""
export DASHSCOPE_API_BASE_URL=""
export DASHSCOPE_ASR_WEBSOCKET_URL=""
export DASHSCOPE_TTS_WEBSOCKET_URL=""

# -----------------------------------------------------------------------------
# 讯飞声通中英文口语评测
# -----------------------------------------------------------------------------

# 是否启用讯飞评测。启用后，用户保存的录音会发送给讯飞并返回单词、音素评分。
export XUNFEI_ASSESSMENT_ENABLED="false"

# 启用评测时必填。这里只能填写服务端密钥，不能暴露给浏览器。
export XUNFEI_APP_ID=""
export XUNFEI_API_KEY=""
export XUNFEI_API_SECRET=""

# 讯飞评测本地侧车的监听地址，以及 Go 后端访问侧车的地址。
# 单机开发通常无需修改；部署到不同容器时需要按网络拓扑调整。
export PRONUNCIATION_ASSESSMENT_ADDR="127.0.0.1:8767"
export PRONUNCIATION_ASSESSMENT_BASE_URL="http://127.0.0.1:8767"

# -----------------------------------------------------------------------------
# LiveKit 端到端实时通话
# -----------------------------------------------------------------------------

# 服务端功能开关和浏览器构建开关必须保持一致。
export LIVEKIT_VOICE_ENABLED="false"
export NEXT_PUBLIC_LIVEKIT_VOICE_ENABLED="false"

# 启用实时通话时，以下三个 LiveKit 参数必填。
export LIVEKIT_URL=""
export LIVEKIT_API_KEY=""
export LIVEKIT_API_SECRET=""

# 浏览器参与者 Token 有效期，单位为秒；后端会限制最大值为 600 秒。
export LIVEKIT_TOKEN_TTL_SECONDS="600"

# LiveKit Worker 访问 Go 后端的地址。
export GO_BACKEND_URL="http://127.0.0.1:8080"

# Worker 调用后端 LLM/TTS 的单轮超时时间，单位为毫秒。
export LIVE_AGENT_PROVIDER_TIMEOUT_MS="30000"

# -----------------------------------------------------------------------------
# 后端与前端地址
# -----------------------------------------------------------------------------

# Go API 的监听地址。空主机表示监听所有本机网卡。
export AGENT_DEMO_ADDR=":8080"

# 浏览器访问 Go API 的公开地址；修改后需要重新启动或构建前端。
export NEXT_PUBLIC_AGENT_API_URL="http://localhost:8080"

# 流式压力测试脚本访问 Go API 的地址。
export AGENT_API_BASE="http://localhost:8080"

# -----------------------------------------------------------------------------
# 本地持久化与 Mem0
# -----------------------------------------------------------------------------

# 对话、附件和记忆数据目录。留空时启动脚本使用项目根目录下的 .data。
export AGENT_DATA_DIR=""
export MEM0_DATA_DIR=""

# Mem0 本地侧车地址。BASE_URL 供 Go 后端访问，ADDR 是侧车监听地址。
export MEM0_BASE_URL="http://127.0.0.1:8766"
export MEM0_ADDR="127.0.0.1:8766"

# text-embedding-v4 的向量维度，必须与已有向量库保持一致。
export MEM0_EMBEDDING_DIMS="1024"

# 是否开启 Mem0 遥测。
export MEM0_TELEMETRY="false"

# 是否把旧版 active memory 文本一次性发送给 DashScope 并导入 Mem0。
# 只有明确需要迁移旧数据时才改为 1。
export MEM0_IMPORT_LEGACY="0"
