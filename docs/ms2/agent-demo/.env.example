# Required: Alibaba Cloud Model Studio API Key for China (Beijing).
export DASHSCOPE_API_KEY="sk-your-key"

# Optional model and voice overrides.
export DASHSCOPE_CHAT_MODEL="qwen3.5-flash"
export DASHSCOPE_EMBEDDING_MODEL="text-embedding-v4"
export DASHSCOPE_DOCUMENT_MODEL="qwen-long"
export DASHSCOPE_ASR_MODEL="qwen3-asr-flash-realtime"
export DASHSCOPE_TTS_MODEL="qwen-audio-3.0-tts-flash"
export DASHSCOPE_TTS_VOICE="longanlingxi"

# Optional realtime voice. The feature remains unavailable unless the flag and
# all three LiveKit connection values are configured.
export LIVEKIT_VOICE_ENABLED="false"
# Browser rollout flag. Keep this equal to LIVEKIT_VOICE_ENABLED.
export NEXT_PUBLIC_LIVEKIT_VOICE_ENABLED="false"
# export LIVEKIT_URL="wss://your-project.livekit.cloud"
# export LIVEKIT_API_KEY="your-livekit-api-key"
# export LIVEKIT_API_SECRET="your-livekit-api-secret"
# Browser participant tokens are short-lived and capped at 600 seconds.
# export LIVEKIT_TOKEN_TTL_SECONDS="600"

# LiveKit Worker. GO_BACKEND_URL is server-side only.
export GO_BACKEND_URL="http://127.0.0.1:8080"
# Per-turn LLM/TTS timeout. STT uses a resettable idle timeout of at least 45s.
export LIVE_AGENT_PROVIDER_TIMEOUT_MS="30000"

# Optional durable local state directories. npm run backend defaults both to
# the project-root .data directory, regardless of the caller's working directory.
# export AGENT_DATA_DIR="/absolute/path/to/agent-demo/.data"
# export MEM0_DATA_DIR="/absolute/path/to/agent-demo/.data/mem0"

# Optional Mem0 OSS sidecar overrides.
# export MEM0_BASE_URL="http://127.0.0.1:8766"
# export MEM0_ADDR="127.0.0.1:8766"
# export MEM0_EMBEDDING_DIMS="1024"
# export MEM0_TELEMETRY="false"
# export MEM0_IMPORT_LEGACY="1" # sends old active memory text to DashScope once

# Optional: use the dedicated China (Beijing) workspace domain.
# If omitted, the public dashscope.aliyuncs.com China endpoints are used.
# export DASHSCOPE_WORKSPACE_ID="your-beijing-workspace-id"

# Optional full endpoint overrides.
# export DASHSCOPE_COMPATIBLE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# export DASHSCOPE_API_BASE_URL="https://dashscope.aliyuncs.com/api/v1"
# export DASHSCOPE_ASR_WEBSOCKET_URL="wss://dashscope.aliyuncs.com/api-ws/v1/realtime"
# export DASHSCOPE_TTS_WEBSOCKET_URL="wss://dashscope.aliyuncs.com/api-ws/v1/inference"
