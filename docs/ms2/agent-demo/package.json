{
  "name": "speakup-agent-demo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace frontend --",
    "backend": "npm run start --workspace backend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace frontend",
    "test": "npm run test --workspace frontend",
    "test:frontend": "npm run test --workspace frontend",
    "test:server": "npm run test:go --workspace backend",
    "test:mem0": "npm run test:mem0 --workspace backend",
    "test:all": "npm run test --workspace backend && npm run test --workspace frontend",
    "test:soak": "npm run test:soak --workspace backend --",
    "lint": "npm run lint --workspace frontend",
    "db:generate": "npm run db:generate --workspace frontend"
  }
}
